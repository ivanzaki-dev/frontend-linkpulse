# BACKEND API only (NOT the frontend Coolify URL)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000/v1
# Staging backend: https://mo5ub2s6knxuqchfa3m925ep.app.ivanzaki.online/v1
# Frontend admin UI: https://ji3qif2znquf1r9uatwp3s8e.app.ivanzaki.online/admin/login

# Footer: link "Masuk mode uji" + Admin (set false on public production)
NEXT_PUBLIC_SHOW_DEV_LINKS=true

# Admin dashboard: tombol seed statistik demo (staging only)
NEXT_PUBLIC_ADMIN_SEED_ENABLED=false

# Server-only — forward to backend webhook (do not expose as NEXT_PUBLIC_)
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret-change-me
API_URL=http://127.0.0.1:3000/v1
